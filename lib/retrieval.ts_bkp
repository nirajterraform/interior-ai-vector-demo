  living_room: [
    { bucket: "seating", categories: ["sofa", "chair"], limit: 8, required: true },
    { bucket: "tables", categories: ["coffee_table", "side_table"], limit: 6, required: true },
    { bucket: "lighting", categories: ["lamp"], limit: 6, required: true },
    { bucket: "wall_art", categories: ["wall_art"], limit: 6, required: false },
    { bucket: "decor", categories: ["decor", "floral_arrangement"], limit: 10, required: false },
    { bucket: "storage", categories: ["cabinet", "shelf"], limit: 6, required: false },
    { bucket: "soft_furnishing", categories: ["rug"], limit: 6, required: false },
  ],
  bedroom: [
    { bucket: "bed", categories: ["bed"], limit: 6, required: true },
    { bucket: "bedside_storage", categories: ["side_table", "dresser"], limit: 6, required: true },
    { bucket: "lighting", categories: ["lamp"], limit: 6, required: true },
    { bucket: "mirror_wall_art", categories: ["mirror", "wall_art"], limit: 6, required: false },
    { bucket: "decor", categories: ["decor", "floral_arrangement"], limit: 8, required: false },
    { bucket: "soft_furnishing", categories: ["rug", "chair"], limit: 6, required: false },
  ],
  dining_room: [
    { bucket: "dining_table", categories: ["dining_table"], limit: 6, required: true },
    { bucket: "dining_chairs", categories: ["chair"], limit: 8, required: true },
    { bucket: "lighting", categories: ["lamp"], limit: 6, required: false },
    { bucket: "wall_art", categories: ["wall_art", "mirror"], limit: 6, required: false },
    { bucket: "decor", categories: ["decor", "floral_arrangement"], limit: 8, required: false },
    { bucket: "storage", categories: ["cabinet"], limit: 6, required: false },
    { bucket: "soft_furnishing", categories: ["rug"], limit: 4, required: false },
  ],
  kitchen: [
    { bucket: "lighting", categories: ["lamp"], limit: 4, required: false },
    { bucket: "decor", categories: ["decor"], limit: 8, required: true },
    { bucket: "wall_art", categories: ["wall_art"], limit: 4, required: false },
    { bucket: "storage", categories: ["cabinet", "shelf"], limit: 6, required: false },
  ],
  office: [
    { bucket: "seating", categories: ["chair"], limit: 6, required: true },
    { bucket: "storage", categories: ["shelf", "cabinet"], limit: 6, required: false },
    { bucket: "lighting", categories: ["lamp"], limit: 4, required: true },
    { bucket: "wall_art", categories: ["wall_art"], limit: 4, required: false },
    { bucket: "decor", categories: ["decor"], limit: 6, required: false },
    { bucket: "soft_furnishing", categories: ["rug"], limit: 4, required: false },
