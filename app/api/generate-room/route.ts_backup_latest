function levelScore(level: Level): number {
  return level === "none" ? 3 : level === "minor" ? 2 : level === "moderate" ? 1 : 0;
}

function qualityScore(q: Quality): number {
  return q === "excellent" ? 4 : q === "good" ? 3 : q === "acceptable" ? 2 : 0;
}

function computeValidationScore(v: FurnishedRoomValidation): number {
  let score = 0;
  if (v.room_type_correct) score += 4;
  if (v.geometry_preserved) score += 4;
  if (v.windows_preserved) score += 3;
  if (v.doors_preserved) score += 1;
  if (v.curtains_preserved) score += 2;
  if (v.floor_preserved) score += 3;
  if (v.ceiling_preserved) score += 2;
  score += qualityScore(v.theme_match_level) * 2;
  score += qualityScore(v.catalog_alignment_level) * 2;
  score += levelScore(v.structural_drift_level) * 3;
  score += levelScore(v.hallucinated_objects_level) * 3;
  score += levelScore(v.artifacts_level) * 2;
  score += qualityScore(v.overall_quality) * 2;
  if (v.pass) score += 2;
  return score;
}

function isStrongEnoughToStop(v: FurnishedRoomValidation, score: number) {
  return (
    v.pass &&
    v.room_type_correct &&
    v.geometry_preserved &&
    v.structural_drift_level !== "significant" &&
    v.structural_drift_level !== "moderate" &&
    v.catalog_alignment_level !== "poor" &&
    v.theme_match_level !== "poor" &&
    v.hallucinated_objects_level !== "significant" &&
    v.artifacts_level !== "significant" &&
    score >= 28
  );
}

// B3: Primary furniture slots — these get priority in the 6-image reference budget.
// Order matters: Gemini pays most attention to the first images it sees.
const PRIMARY_FURNITURE_SLOTS = ["sofa", "chair", "table", "rug", "lamp", "cabinet", "bed", "desk", "mirror"];

function selectFocusedReferences(
  shortlist: ShortlistItem[],
  authoritativeSelection: AuthoritativeSelectionItem[],
  theme: string,
  maxRefs: number
): ShortlistItem[] {
  // Start with authoritative selection — these are the highest-confidence picks
  const authHandles = new Set(authoritativeSelection.map((x) => x.product_handle));
  const result: ShortlistItem[] = [];
  const usedCategories = new Set<string>();
  const usedHandles = new Set<string>();

  // Pass 1: One authoritative pick per primary furniture slot
  for (const slot of PRIMARY_FURNITURE_SLOTS) {
    if (result.length >= maxRefs) break;
    const match = authoritativeSelection.find((item) => {
      if (!item.product_handle || usedHandles.has(item.product_handle)) return false;
      const cat = canonicalizeCategory(item.normalized_category || item.category || item.bucket || "");
      return cat === slot || (item.requestedCategory && canonicalizeCategory(item.requestedCategory) === slot);
    });
    if (match) {
      result.push(match);
      usedHandles.add(match.product_handle);
      usedCategories.add(canonicalizeCategory(match.normalized_category || match.category || match.bucket || ""));
    }
  }

  // Pass 2: Fill remaining slots from shortlist, one per uncovered category
  if (result.length < maxRefs) {
    const scored = prioritizeShortlist(shortlist, theme, maxRefs * 3);
    for (const item of scored) {
      if (result.length >= maxRefs) break;
      if (!item.product_handle || usedHandles.has(item.product_handle)) continue;
      const cat = canonicalizeCategory(item.normalized_category || item.category || item.bucket || "");
      if (!usedCategories.has(cat)) {
        result.push(item);
        usedHandles.add(item.product_handle);
        usedCategories.add(cat);
      }
    }
  }

  return result;
}

// For detection: use the FULL shortlist (up to MAX_PINNED_DETECTION_REFERENCE_IMAGES)
// More diverse references = better chance of finding a visual match for what Imagen generated.
// Unlike generation (which needs focused refs to avoid confusion), detection benefits from breadth.
async function buildDetectionReferenceParts(shortlist: ShortlistItem[], authoritativeSelection: AuthoritativeSelectionItem[], theme: string) {
  // Use ALL shortlist items, prioritising authoritative picks first, up to detection cap
  const authHandles = new Set((authoritativeSelection || []).map((x) => x.product_handle));
  const sorted = [
    ...shortlist.filter((x) => authHandles.has(x.product_handle)),
    ...shortlist.filter((x) => !authHandles.has(x.product_handle)),
  ].filter((x) => !!x.image_url).slice(0, MAX_PINNED_DETECTION_REFERENCE_IMAGES);

  const resolved = await Promise.all(
    sorted.map(async (item) => {
      try {
        const part = await urlToInlineData(item.image_url as string);
        return { ok: true as const, part, item };
      } catch (err: any) {
        const status = String(err?.message ?? "").match(/status (\d+)/)?.[1];
        if (status !== "404") {
          console.warn("Skipping detection image:", item.image_url, status ?? String(err));
        }
        return { ok: false as const, part: null, item };
      }
    })
  );

  const fetched = resolved.filter((x) => x.ok && x.part !== null);
  return {
    catalogueImageParts: fetched.map((x) => x.part) as GeminiImagePart[],
    validShortlist: fetched.map((x) => x.item),
  };
}

async function buildReferenceParts(shortlist: ShortlistItem[], authoritativeSelection: AuthoritativeSelectionItem[], theme: string) {
  // B3: Use focused reference selection — one per furniture category, prioritising
  // authoritative picks. This beats sending 14 diverse images where Gemini gets confused.
  const prioritized = selectFocusedReferences(
    shortlist,
    authoritativeSelection?.length
      ? authoritativeSelection
      : ensureSelectionCoverage(shortlist, authoritativeSelection, theme),
    theme,
    MAX_GENERATION_REFERENCE_IMAGES
  );

  const resolved = await Promise.all(
    prioritized.map(async (item) => {
      try {
        const part = await urlToInlineData(item.image_url as string);
        return { ok: true as const, part, item };
      } catch (err: any) {
        const status = String(err?.message ?? "").match(/status (\d+)/)?.[1];
        if (status !== "404") {
          console.warn("Skipping catalogue image:", item.image_url, status ?? String(err));
        }
        return { ok: false as const, part: null, item };
      }
    })
  );

  const fetched = resolved.filter((x) => x.ok && x.part !== null);
  return {
    referenceParts: fetched.map((x) => x.part),
    validShortlist: fetched.map((x) => x.item),
    catalogueImageParts: fetched.map((x) => x.part) as GeminiImagePart[],
  };
}

